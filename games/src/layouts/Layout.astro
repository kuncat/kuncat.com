---
import "../styles/global.css";

type FaviconInput = string | { src?: string } | null | undefined;

const { favicon, title }: { favicon?: FaviconInput; title?: string } = Astro.props;
const faviconHref = typeof favicon === "string" ? favicon : (favicon?.src ?? "/favicon.svg");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? "Kuncat"}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
